# .env.example - Template for environment variables
# Copy this file to .env and fill in the actual values

# --- Backend Configuration ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=talent_flow_ats
DB_USER=postgres
DB_PASSWORD=Pass2020NothingSpecial # Change this to a secure password
SECRET_KEY=supersecretkey1234567890123456 # Change this to a long random string

# --- AI Configuration ---
# Hugging Face Token for Llama models
HF_TOKEN=your_huggingface_token_here

# Google Gemini API Key (if used in the future)
# GOOGLE_API_KEY=your_gemini_key_here

# --- Frontend Configuration ---
# Prefix with NEXT_PUBLIC_ for client-side access
NEXT_PUBLIC_API_URL=http://localhost:4000
